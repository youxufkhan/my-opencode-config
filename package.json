    "node": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.38.1",
    "@types/node": "^20.19.39",
    "astro": "^6.0.4",
